# ============================================================
# 🌅 아침 브리핑 — .gitignore
# ============================================================

# ── 환경변수 (절대 커밋 금지!) ───────────────────────────────
.env

# ── 실행 결과물 ──────────────────────────────────────────────
briefing_output.html
briefing_log.txt

# ── Python 캐시 ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# ── 가상환경 ─────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
